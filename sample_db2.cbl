IDENTIFICATION DIVISION.
PROGRAM-ID. CUSTOMER-MGMT.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.

DATA DIVISION.
WORKING-STORAGE SECTION.
01 DB-CREDENTIALS.
   05 DB-USER     PIC X(10) VALUE "ADMIN".
   05 DB-PASS     PIC X(10) VALUE "P@SSW0RD1".

01 CUST-RECORD.
   05 CUST-ID     PIC 9(5).
   05 CUST-NAME   PIC X(30).
   05 CUST-BAL    PIC 9(7)V99.

EXEC SQL INCLUDE SQLCA END-EXEC.

PROCEDURE DIVISION.
MAIN-PARAGRAPH.
    MOVE 10045 TO CUST-ID.
    
    PERFORM CONNECT-DB.
    PERFORM FETCH-CUSTOMER.
    
    STOP RUN.

CONNECT-DB.
    EXEC SQL
      CONNECT TO DB2DATABASE USER :DB-USER USING :DB-PASS
    END-EXEC.

FETCH-CUSTOMER.
    EXEC SQL
       SELECT NAME, BALANCE 
       INTO :CUST-NAME, :CUST-BAL
       FROM CUSTOMERS 
       WHERE ID = :CUST-ID
    END-EXEC.
    
    DISPLAY "Fetched Customer: " CUST-NAME " Balance: " CUST-BAL.

CALL-EXTERNAL-SVC.
    CALL "PROPRIETARY_AUTH_SVC" USING CUST-ID.
